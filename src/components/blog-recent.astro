---
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => data.draft !== true);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const latestPost = posts[0];
---

{latestPost && (
  <section id="latest-blog" class="py-4 md:py-20 px-4 md:px-0 overflow-hidden reveal-content" style="animation-delay: 100ms;">
    <div class="container mx-auto">
      <div class="mb-10 md:mb-12 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div>
          <h2 class="text-3xl md:text-4xl font-heading font-bold text-white mb-2 flex items-center gap-4">
            <span class="text-accent">/</span> Blog - Recente
          </h2>
          <p class="text-gray font-body text-sm max-w-md">
            Conteudo novo saindo do forno. Leia o artigo mais recente do blog.
          </p>
        </div>

        <a href="/blog" class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-white/10 bg-white/[0.03] text-gray-200 hover:text-accent hover:border-accent/30 transition-all duration-300 font-body text-sm">
          Ver todos os posts
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
            <path d="M16.1716 10.9999L10.8076 5.63589L12.2218 4.22168L20 11.9999L12.2218 19.778L10.8076 18.3638L16.1716 12.9999H4V10.9999H16.1716Z"></path>
          </svg>
        </a>
      </div>

      <a href={`/blog/${latestPost.id}`} class="blog-card group block p-6 md:p-8 bg-white/[0.03] border border-white/[0.06] rounded-2xl hover:border-accent/30 hover:bg-accent/[0.03] transition-all duration-500">
        <div class="flex flex-col md:flex-row md:items-start gap-4 md:gap-8">
          <div class="md:w-28 shrink-0">
            <time datetime={latestPost.data.pubDate.toISOString()} class="text-accent/70 font-heading text-xs uppercase tracking-wider font-bold">
              {latestPost.data.pubDate.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' })}
            </time>
          </div>

          <div class="flex-1 min-w-0">
            <h3 class="text-xl md:text-2xl font-heading font-bold text-white group-hover:text-accent transition-colors duration-300 mb-2">
              {latestPost.data.title}
            </h3>

            <p class="text-gray-400 font-body text-sm leading-relaxed mb-4 line-clamp-2">
              {latestPost.data.description}
            </p>

            <div class="flex items-center justify-between gap-4">
              <div class="flex flex-wrap gap-2">
                {latestPost.data.tags.map((tag) => (
                  <span class="px-2.5 py-0.5 bg-accent/10 text-accent/80 rounded-md text-[10px] font-medium uppercase tracking-wider border border-accent/10">
                    {tag}
                  </span>
                ))}
              </div>

              <span class="text-white/30 group-hover:text-accent group-hover:translate-x-1 transition-all duration-300 hidden md:block" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
                  <path d="M16.1716 10.9999L10.8076 5.63589L12.2218 4.22168L20 11.9999L12.2218 19.778L10.8076 18.3638L16.1716 12.9999H4V10.9999H16.1716Z"></path>
                </svg>
              </span>
            </div>
          </div>
        </div>
      </a>
    </div>
  </section>
)}

<style>
  .reveal-content {
    opacity: 0;
    transform: translateY(20px);
    animation: revealIn 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }

  @keyframes revealIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .blog-card {
    position: relative;
    overflow: hidden;
  }

  .blog-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 0;
    background: var(--color-accent);
    border-radius: 0 2px 2px 0;
    transition: height 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .blog-card:hover::before {
    height: 100%;
  }
</style>
