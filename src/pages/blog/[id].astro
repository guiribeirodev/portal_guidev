---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BlogLayout title={`${post.data.title} | Blog`} description={post.data.description}>
  <article class="reveal-content" style="animation-delay: 100ms;">
    <!-- Post Header -->
    <header class="mb-12 pb-8 border-b border-white/5">
      <div class="flex flex-wrap gap-2 mb-4">
        {post.data.tags.map(tag => (
          <a href={`/blog`} class="px-3 py-1 bg-accent/10 text-accent/80 rounded-full text-[10px] font-medium uppercase tracking-wider border border-accent/10 hover:bg-accent/20 transition-colors">
            {tag}
          </a>
        ))}
      </div>
      <h1 class="text-3xl md:text-5xl font-heading font-bold text-white leading-tight mb-4">
        {post.data.title}
      </h1>
      <p class="text-gray font-body text-base md:text-lg leading-relaxed mb-6">
        {post.data.description}
      </p>
      <div class="flex items-center gap-4 text-sm text-gray-400 font-body">
        <time datetime={post.data.pubDate.toISOString()} class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" class="text-accent/60">
            <path d="M9 1V3H15V1H17V3H21C21.5523 3 22 3.44772 22 4V20C22 20.5523 21.5523 21 21 21H3C2.44772 21 2 20.5523 2 20V4C2 3.44772 2.44772 3 3 3H7V1H9ZM20 11H4V19H20V11ZM7 5H4V9H20V5H17V7H15V5H9V7H7V5Z"></path>
          </svg>
          {post.data.pubDate.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })}
        </time>
        {post.data.updatedDate && (
          <span class="text-gray-500">
            · Atualizado em {post.data.updatedDate.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })}
          </span>
        )}
      </div>
    </header>

    <!-- Post Content -->
    <div class="prose-blog">
      <Content />
    </div>

    <!-- Post Footer -->
    <footer class="mt-16 pt-8 border-t border-white/5">
      <a href="/blog" class="inline-flex items-center gap-2 text-accent hover:text-white transition-colors duration-300 font-heading font-medium group">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="currentColor" class="group-hover:-translate-x-1 transition-transform duration-300">
          <path d="M7.82843 10.9999H20V12.9999H7.82843L13.1924 18.3638L11.7782 19.778L4 11.9999L11.7782 4.22168L13.1924 5.63589L7.82843 10.9999Z"></path>
        </svg>
        Voltar para o Blog
      </a>
    </footer>
  </article>
</BlogLayout>

<style is:global>
  .reveal-content {
    opacity: 0;
    transform: translateY(20px);
    animation: revealIn 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }
  @keyframes revealIn {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Blog Prose Styles */
  .prose-blog {
    font-family: var(--font-body);
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.8;
    font-size: 1.05rem;
  }

  .prose-blog h1,
  .prose-blog h2,
  .prose-blog h3,
  .prose-blog h4 {
    font-family: var(--font-heading);
    color: white;
    font-weight: 700;
    line-height: 1.3;
    margin-top: 2.5em;
    margin-bottom: 0.8em;
  }

  .prose-blog h1 { font-size: 2rem; }
  .prose-blog h2 {
    font-size: 1.5rem;
    padding-bottom: 0.4em;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  .prose-blog h3 { font-size: 1.25rem; }
  .prose-blog h4 { font-size: 1.1rem; }

  .prose-blog p {
    margin-bottom: 1.5em;
  }

  .prose-blog a {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--color-accent), transparent 60%);
    text-underline-offset: 3px;
    transition: all 0.2s;
  }
  .prose-blog a:hover {
    text-decoration-color: var(--color-accent);
  }

  .prose-blog strong { color: white; font-weight: 600; }
  .prose-blog em { color: rgba(255, 255, 255, 0.9); }

  .prose-blog ul, .prose-blog ol {
    margin-bottom: 1.5em;
    padding-left: 1.5em;
  }
  .prose-blog ul { list-style: disc; }
  .prose-blog ol { list-style: decimal; }
  .prose-blog li {
    margin-bottom: 0.5em;
    padding-left: 0.25em;
  }
  .prose-blog li::marker {
    color: var(--color-accent);
  }

  .prose-blog blockquote {
    border-left: 3px solid var(--color-accent);
    padding: 1em 1.5em;
    margin: 2em 0;
    background: rgba(164, 118, 255, 0.05);
    border-radius: 0 12px 12px 0;
    font-style: italic;
    color: rgba(255, 255, 255, 0.7);
  }

  .prose-blog pre {
    background: rgba(0, 0, 0, 0.4) !important;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px;
    padding: 1.25em 1.5em;
    margin: 2em 0;
    overflow-x: auto;
    font-size: 0.9em;
    line-height: 1.6;
  }

  .prose-blog :not(pre) > code {
    background: rgba(164, 118, 255, 0.12);
    color: var(--color-accent);
    padding: 0.15em 0.4em;
    border-radius: 5px;
    font-size: 0.88em;
    font-weight: 500;
  }

  .prose-blog hr {
    border: none;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(255, 255, 255, 0.1), transparent);
    margin: 3em 0;
  }

  .prose-blog img {
    border-radius: 12px;
    margin: 2em auto;
    max-width: 100%;
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .prose-blog table {
    width: 100%;
    border-collapse: collapse;
    margin: 2em 0;
  }
  .prose-blog th, .prose-blog td {
    padding: 0.75em 1em;
    border: 1px solid rgba(255, 255, 255, 0.06);
    text-align: left;
  }
  .prose-blog th {
    background: rgba(255, 255, 255, 0.03);
    font-weight: 600;
    color: white;
  }
</style>
