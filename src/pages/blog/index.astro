---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => data.draft !== true);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const allTags = [...new Set(posts.flatMap(post => post.data.tags))];
---

<BlogLayout title="Blog | Gui Ribeiro" description="Artigos sobre dev e tecnologia.">
  <div class="reveal-content" style="animation-delay: 100ms;">
    <div class="mb-12 md:mb-16">
      <div class="flex items-center gap-3 mb-4">
        <div class="h-px flex-1 bg-gradient-to-r from-accent/50 to-transparent"></div>
        <span class="text-accent font-heading text-xs uppercase tracking-[0.3em] font-bold">Blog</span>
        <div class="h-px flex-1 bg-gradient-to-l from-accent/50 to-transparent"></div>
      </div>
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-white text-center mb-4">Pensamentos & Código</h1>
      <p class="text-gray text-center font-body max-w-lg mx-auto text-sm md:text-base">
        Artigos sobre desenvolvimento, tecnologia e experiências ao longo da minha jornada como dev.
      </p>
    </div>
  </div>

  {allTags.length > 0 && (
    <div class="flex flex-wrap justify-center gap-2 mb-12 reveal-content" style="animation-delay: 200ms;">
      <button data-tag="all" class="tag-filter active px-4 py-1.5 rounded-full text-xs font-body font-medium border transition-all duration-300 cursor-pointer">Todos</button>
      {allTags.map(tag => (
        <button data-tag={tag} class="tag-filter px-4 py-1.5 rounded-full text-xs font-body font-medium border transition-all duration-300 cursor-pointer">{tag}</button>
      ))}
    </div>
  )}

  <div class="space-y-6" id="posts-container">
    {posts.map((post, index) => (
      <a href={`/blog/${post.id}`} class="blog-card group block p-6 md:p-8 bg-white/[0.03] border border-white/[0.06] rounded-2xl hover:border-accent/30 hover:bg-accent/[0.03] transition-all duration-500 reveal-content" style={`animation-delay: ${300 + index * 100}ms;`} data-tags={JSON.stringify(post.data.tags)}>
        <div class="flex flex-col md:flex-row md:items-start gap-4 md:gap-8">
          <div class="md:w-28 shrink-0">
            <time datetime={post.data.pubDate.toISOString()} class="text-accent/70 font-heading text-xs uppercase tracking-wider font-bold">
              {post.data.pubDate.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' })}
            </time>
          </div>
          <div class="flex-1 min-w-0">
            <h2 class="text-xl md:text-2xl font-heading font-bold text-white group-hover:text-accent transition-colors duration-300 mb-2">{post.data.title}</h2>
            <p class="text-gray-400 font-body text-sm leading-relaxed mb-4 line-clamp-2">{post.data.description}</p>
            <div class="flex items-center justify-between">
              <div class="flex flex-wrap gap-2">
                {post.data.tags.map(tag => (
                  <span class="px-2.5 py-0.5 bg-accent/10 text-accent/80 rounded-md text-[10px] font-medium uppercase tracking-wider border border-accent/10">{tag}</span>
                ))}
              </div>
              <span class="text-white/30 group-hover:text-accent group-hover:translate-x-1 transition-all duration-300 hidden md:block">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
                  <path d="M16.1716 10.9999L10.8076 5.63589L12.2218 4.22168L20 11.9999L12.2218 19.778L10.8076 18.3638L16.1716 12.9999H4V10.9999H16.1716Z"></path>
                </svg>
              </span>
            </div>
          </div>
        </div>
      </a>
    ))}
  </div>

  {posts.length === 0 && (
    <div class="text-center py-20">
      <p class="text-gray-400 font-body text-lg">Nenhum post publicado ainda.</p>
    </div>
  )}
</BlogLayout>

<style>
  .reveal-content {
    opacity: 0;
    transform: translateY(20px);
    animation: revealIn 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }
  @keyframes revealIn {
    to { opacity: 1; transform: translateY(0); }
  }
  .tag-filter {
    color: rgba(255,255,255,0.5);
    border-color: rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.02);
  }
  .tag-filter:hover {
    color: var(--color-accent);
    border-color: color-mix(in srgb, var(--color-accent), transparent 60%);
    background: color-mix(in srgb, var(--color-accent), transparent 92%);
  }
  .tag-filter.active {
    color: var(--color-accent);
    border-color: color-mix(in srgb, var(--color-accent), transparent 40%);
    background: color-mix(in srgb, var(--color-accent), transparent 85%);
    box-shadow: 0 0 20px color-mix(in srgb, var(--color-accent), transparent 80%);
  }
  .blog-card { position: relative; overflow: hidden; }
  .blog-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 3px; height: 0;
    background: var(--color-accent);
    border-radius: 0 2px 2px 0;
    transition: height 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .blog-card:hover::before { height: 100%; }
</style>

<script>
  const tagButtons = document.querySelectorAll('.tag-filter');
  const postCards = document.querySelectorAll('.blog-card');
  tagButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      tagButtons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const selectedTag = btn.getAttribute('data-tag');
      postCards.forEach(card => {
        const el = card as HTMLElement;
        if (selectedTag === 'all') { el.style.display = 'block'; el.style.opacity = '1'; return; }
        const tags = JSON.parse(el.getAttribute('data-tags') || '[]');
        if (tags.includes(selectedTag)) { el.style.display = 'block'; setTimeout(() => { el.style.opacity = '1'; }, 50); }
        else { el.style.opacity = '0'; setTimeout(() => { el.style.display = 'none'; }, 300); }
      });
    });
  });
</script>
